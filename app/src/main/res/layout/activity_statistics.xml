<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stat_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/statistics_title"
            app:titleTextColor="@color/text_display_color" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_data_hint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_stat_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="@color/text_display_color" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_stat"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="@string/clear_data"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_example_stat"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/example_data"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_calculate_stat"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/calculate"
                app:cornerRadius="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/result_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Averages Section -->
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_mean" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_median" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_mode" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="12dp" android:background="@color/divider_color" />

                    <!-- Dispersion Section -->
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_std_dev" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_variance" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_range" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="12dp" android:background="@color/divider_color" />

                    <!-- Quartiles Section -->
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_q1" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_q3" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_iqr" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="12dp" android:background="@color/divider_color" />

                    <!-- Summary Section -->
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_min" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_max" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_sum" />
                    <include layout="@layout/layout_stat_row" android:id="@+id/row_count" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>