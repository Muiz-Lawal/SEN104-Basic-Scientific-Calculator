<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/matrix_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MatrixActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/matrix_title"
        app:titleTextColor="@color/text_display_color" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dimensions: "
                    android:textColor="@color/text_secondary_color"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_dimensions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:singleSelection="true"
                    app:checkedButton="@+id/btn_3x3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_2x2"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2x2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_3x3"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3x3" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matrix A"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/grid_matrix_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="8dp"
                android:columnCount="3"
                android:rowCount="3">
                <!-- Programmatically add EditTexts -->
            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matrix B"
                android:textColor="@color/secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/grid_matrix_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="8dp"
                android:columnCount="3"
                android:rowCount="3">
                <!-- Programmatically add EditTexts -->
            </GridLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_matrix"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A+B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sub_matrix"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A-B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mul_matrix"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AxB" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_det_a"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Det(A)" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_transpose_a"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aᵀ" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_inv_a"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A⁻¹" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_matrices"
                        style="@style/MatrixButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        app:icon="@android:drawable/ic_menu_delete" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/result_matrix_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Result"
                android:textColor="@color/text_secondary_color"
                android:textSize="18sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/display_matrix_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/display_background"
                android:padding="16dp"
                android:textColor="@color/text_display_color"
                android:textSize="18sp"
                android:typeface="monospace"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>