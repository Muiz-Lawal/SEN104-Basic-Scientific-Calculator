<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Calculator" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <style name="Theme.Calculator" parent="Base.Theme.Calculator" />

    <!-- Custom Button Styles for Scientific Calculator -->
    <style name="CalcButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_margin">2dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CalcButton.Numeric">
        <item name="android:textColor">@color/number_color</item>
    </style>

    <style name="CalcButton.Operator">
        <item name="android:textColor">@color/operator_color</item>
    </style>

    <style name="CalcButton.Function">
        <item name="android:textColor">@color/function_color</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="CalcButton.Control">
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="CalcButton.Equals" parent="Widget.Material3.Button">
        <item name="android:layout_margin">2dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/background</item>
    </style>

    <style name="MatrixButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_margin">4dp</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>