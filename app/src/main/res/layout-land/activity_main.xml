<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Screen Guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3" />

    <!-- Display Area -->
    <LinearLayout
        android:id="@+id/display_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/display_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/text_secondary_color"
            android:textSize="18sp"
            tools:text="sin(30) + log(10)" />

        <TextView
            android:id="@+id/display_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/text_display_color"
            android:textSize="32sp"
            android:textStyle="bold"
            tools:text="1.5" />
    </LinearLayout>

    <!-- Controls Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline_vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_history"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/history"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_matrix"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/matrix"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_statistics"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/statistics"
                android:textSize="10sp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="10"
            android:padding="4dp">

            <!-- Scientific Functions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sin"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/sin" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_asin"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/asin" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cos"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/cos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_acos"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/acos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tan"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/tan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_atan"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/atan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sinh"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/sinh" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cosh"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/cosh" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tanh"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/tanh" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_abs"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/abs" />

            <!-- Row 2 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_log"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/log" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ln"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/ln" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_log2"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/log2" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_exp"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/exp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sqrt"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/sqrt" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_power"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/power" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_nCr"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/nCr" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_nPr"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/nPr" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_factorial"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/factorial" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_inv"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/inv" />

            <!-- Row 3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sum"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/sum" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_avg"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/avg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_min"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/min" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_max"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/max" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ceil"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/ceil" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_floor"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/floor" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_med"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/med" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_std"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/std" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_var"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/var" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rand"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/rand" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pi"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/pi" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_e"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/e" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_deg_rad"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:text="@string/deg"
                android:textSize="10sp" />

            <!-- Standard Rows -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_7"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_8"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_9"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n9" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/clear"
                android:textColor="@android:color/holo_red_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/delete"
                android:textColor="@android:color/holo_orange_light"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_brackets"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/brackets" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_percent"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/percent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_comma"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/comma" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_divide"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/divide" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_multiply"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/multiply" />

            <!-- Row 2 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_4"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_5"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_6"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_1"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_2"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n2" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_3"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_0"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/n0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dot"
                style="@style/CalcButton.Numeric"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/dot" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_subtract"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/subtract" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="@string/add" />

            <!-- Row 3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ans"
                style="@style/CalcButton.Control"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="2"
                android:layout_columnSpan="2"
                android:text="@string/ans" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_equals"
                style="@style/CalcButton.Equals"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="6"
                android:layout_columnSpan="6"
                android:text="@string/equals" />

        </GridLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>